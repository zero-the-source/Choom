{
  "name": "choom-ai-companion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"memory,next\" --prefix-colors \"yellow,blue\" \"pnpm run memory:start\" \"next dev 2>&1 | node scripts/log-filter.js\"",
    "dev:verbose": "pnpm run memory:start & next dev",
    "dev:app": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:views": "sqlite3 prisma/dev.db < prisma/create-views.sql",
    "memory:start": "cd ../memory-server && ./run.sh",
    "memory:stop": "pkill -f 'python run.py' || true",
    "services:check": "./services/signal-bridge/start.sh",
    "signal:logs": "journalctl -u signal-bridge -f",
    "signal:restart": "sudo systemctl restart signal-bridge",
    "db:seed": "pnpm dlx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "pnpm dlx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/pdfkit": "^0.17.4",
    "@types/sharp": "^0.31.1",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.27.3",
    "lucide-react": "^0.460.0",
    "next": "^16.2.6",
    "pdfkit": "^0.17.2",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.1",
    "three": "^0.183.2",
    "undici": "^8.1.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.14",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
